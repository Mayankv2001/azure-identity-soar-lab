// DET-CICD-001 | Compromised CI/CD pipeline: workload-identity credential bridging | v2.0.0
// Tactics: Credential Access, Privilege Escalation, Lateral Movement
// Techniques: T1552.007 (Unsecured Credentials: Container/Cloud API), T1550.001
//             (Use Alternate Auth Material: Application Access Token),
//             T1098.001 (Additional Cloud Credentials), T1098.003 (Additional Cloud Roles)
//
// SCENARIO
// A GitHub Actions workflow authenticates to Microsoft Entra ID via an OIDC
// federated credential (workload identity federation - no stored secret). If the
// pipeline is compromised (poisoned workflow, malicious PR, pull_request_target
// abuse, or a leaked OIDC subject claim), the attacker "bridges" that short-lived
// federated token into the Azure control plane and either:
//   (a) extracts secrets from Azure Key Vault at abnormal volume, or
//   (b) escalates privilege by assigning itself a role (roleAssignments/write).
//
// DETECTION LOGIC
// 1. Identify service-principal sign-ins that used a GitHub OIDC federated
//    credential (issuer token.actions.githubusercontent.com).
// 2. Within a short bridge window, correlate the SAME service principal object id
//    performing (a) a burst of Key Vault SecretGet, or (b) a roleAssignments/write.
// 3. Escalate when the repo/subject is not on the approved federation allow-list,
//    or the source IP is not a known GitHub-hosted-runner range.
//
// TABLES (enterprise Sentinel)
//   AADServicePrincipalSignInLogs  - federated SP sign-ins (FederatedCredentialId,
//                                    ServicePrincipalId, IPAddress, ResourceDisplayName)
//   AzureDiagnostics (KeyVault)    - ResourceType == "VAULTS", OperationName "SecretGet"
//   AzureActivity                  - Microsoft.Authorization/roleAssignments/write
//   _GetWatchlist('ApprovedFederatedIdentities') - approved repo:subject -> SP mapping
//
// NOTE: column availability varies by tenant/diagnostic settings; validate against
// the target workspace before enabling (this rule ships DISABLED - see the YAML).
let bridge_window = 30m;
let github_oidc_issuer = "token.actions.githubusercontent.com";
let approved =
    _GetWatchlist('ApprovedFederatedIdentities')
    | project ApprovedSpId = tostring(ServicePrincipalId),
              ApprovedSubject = tostring(Subject);   // e.g. repo:contoso/app:ref:refs/heads/main
// 1) GitHub OIDC federated service-principal sign-ins
let oidc_signins =
    AADServicePrincipalSignInLogs
    | where TimeGenerated > ago(1d)
    | where ResultType == 0
    | extend Issuer = tostring(parse_json(tostring(AuthenticationProcessingDetails))
                               .["Oauth Token Issuer"])
    | where FederatedCredentialId != "" or Issuer has github_oidc_issuer
    | project SignInTime = TimeGenerated, ServicePrincipalId, ServicePrincipalName,
              IPAddress, FederatedCredentialId,
              Subject = tostring(parse_json(tostring(AuthenticationProcessingDetails)).["Subject"]);
// 2a) Key Vault secret extraction by that principal
let kv_secret_reads =
    AzureDiagnostics
    | where TimeGenerated > ago(1d)
    | where ResourceType == "VAULTS"
    | where OperationName in ("SecretGet", "SecretList", "KeyGet")
    | extend SpId = tostring(identity_claim_oid_g)
    | summarize SecretReads = count(), Vaults = make_set(Resource, 10),
                FirstRead = min(TimeGenerated), LastRead = max(TimeGenerated)
        by SpId;
// 2b) Privilege escalation by that principal
let role_grants =
    AzureActivity
    | where TimeGenerated > ago(1d)
    | where OperationNameValue == "Microsoft.Authorization/roleAssignments/write"
    | where ActivityStatusValue == "Success"
    | extend SpId = tostring(parse_json(tostring(Claims)).["http://schemas.microsoft.com/identity/claims/objectidentifier"])
    | project GrantTime = TimeGenerated, SpId, GrantedScope = _ResourceId,
              GrantedRole = tostring(parse_json(tostring(Properties)).roleDefinitionId);
oidc_signins
| join kind=leftouter approved on $left.ServicePrincipalId == $right.ApprovedSpId
| join kind=leftouter (kv_secret_reads) on $left.ServicePrincipalId == $right.SpId
| join kind=leftouter (role_grants) on $left.ServicePrincipalId == $right.SpId
| extend SecretExtraction = SecretReads > 5
       and (LastRead between (SignInTime .. (SignInTime + bridge_window))),
        PrivilegeEscalation = isnotempty(GrantTime)
       and (GrantTime between (SignInTime .. (SignInTime + bridge_window)))
| where SecretExtraction or PrivilegeEscalation
| extend UnapprovedFederation = isempty(ApprovedSpId) or (ApprovedSubject != Subject)
| extend Severity = case(PrivilegeEscalation and UnapprovedFederation, "Critical",
                         SecretExtraction and UnapprovedFederation, "Critical",
                         PrivilegeEscalation, "High",
                         "High")
| project SignInTime, ServicePrincipalName, ServicePrincipalId, Subject, IPAddress,
          SecretExtraction, SecretReads, Vaults,
          PrivilegeEscalation, GrantedScope, GrantedRole,
          UnapprovedFederation, Severity
| sort by SignInTime asc
